#
# iOS {{ which.capitalize() }} Mode Theme - {{ color }}
#
ios-{{ which }}-mode-{{ color }}{{ suffix }}:
  # ---------------------------------------------------------------------------
  # Core colors and backgrounds
  # ---------------------------------------------------------------------------
  background-image: "center / cover no-repeat fixed url('{{ background }}')"
  lovelace-background: var(--background-image)

  primary-color: {{ primary_color }}  # Apple systemOrange for {{ which }} mode
  accent-color: rgba(255, 159, 9, 1)

  primary-background-color: {{ primary_background_color }}  # Main app surface
  secondary-background-color: {{ secondary_background_color }}  # Secondary/card surface
  divider-color: {{ divider_color }}  # Apple systemGray for {{ which }} mode
  light-primary-color: {{ light_primary_color }}  # Used by some icons, including sidebar icons

  # ---------------------------------------------------------------------------
  # Text
  # ---------------------------------------------------------------------------
  primary-text-color: {{ primary_text_color }}
  secondary-text-color: {{ secondary_text_color }}

  text-primary-color: "#FFF"
  text-dark-color: "#FFF"
  disabled-text-color: "#555"  # See issue #2 in original repo

  # ---------------------------------------------------------------------------
  # Sidebar / navigation drawer
  # ---------------------------------------------------------------------------
  sidebar-background-color: var(--primary-background-color)
  sidebar-icon-color: var(--light-primary-color)
  sidebar-text-color: {{ sidebar_text_color }}

  sidebar-selected-background-color: var(--primary-background-color)
  sidebar-selected-icon-color: {{ sidebar_selected_icon_color }}
  sidebar-selected-text-color: var(--sidebar-selected-icon-color)

  # ---------------------------------------------------------------------------
  # Entity state colors and badges
  # ---------------------------------------------------------------------------
  state-icon-color: "#FFF"
  state-icon-active-color: {{ state_icon_active_color }}
  state-icon-unavailable-color: var(--disabled-text-color)

  label-badge-background-color: "#23232E"
  label-badge-text-color: "#F1F1F1"
  label-badge-red: {{ label_badge_red }}  # Apple systemOrange for {{ which }} mode

  # ---------------------------------------------------------------------------
  # Cards, rows, and general surfaces
  # ---------------------------------------------------------------------------
  card-background-color: var(--secondary-background-color)  # Used by some legacy tables/cards
  ha-card-background: {{ ha_card_background }}
  rgb-card-background-color: {{ rgb_card_background }}  # See issue #60
  ha-card-border-radius: 20px
  ha-card-border-width: 0  # See issue #82

  clear-background-color: var(--ha-card-background)  # See issue #64

  # Table / list surfaces
  data-table-background-color: var(--card-background-color)
  table-header-background-color: var(--secondary-background-color)
  table-row-background-color: var(--primary-background-color)
  table-row-alternative-background-color: var(--secondary-background-color)

  # ---------------------------------------------------------------------------
  # Sliders and switches
  # ---------------------------------------------------------------------------
  # paper-slider-* removed in HA 2025.5; ha-slider follows primary/accent color
  ha-slider-background: none !important

  # paper-toggle-button-* removed in HA 2025.5
  switch-checked-color: "#30d257"
  switch-checked-track-color: {{ switch_checked_track_color }}  # Apple systemGreen for {{ which }} mode
  switch-checked-button-color: "#FFF"

  # ---------------------------------------------------------------------------
  # Dialogs and form controls
  # ---------------------------------------------------------------------------
  dialog-background-color: {{ dialog_background_color }}  # Dialog / popup surface
  ha-dialog-surface-background: {{ dialog_background_color }}
  more-info-header-background: {{ more_info_header_background }}

  # Modern HA form variables
  ha-color-form-background: {{ form_background_color }}
  ha-color-form-background-hover: {{ form_background_color }}
  ha-color-form-background-disabled: {{ form_background_color }}

  # Text/border tokens used by modern HA form controls
  ha-color-text-primary: var(--primary-text-color)
  ha-color-text-secondary: var(--secondary-text-color)
  ha-color-border-neutral-loud: var(--divider-color)
  ha-color-border-neutral-normal: var(--divider-color)
  ha-color-border-neutral-quiet: var(--divider-color)

  # Legacy input vars still used by MDC-based components
  input-fill-color: {{ form_background_color }}
  input-disabled-fill-color: {{ form_background_color }}
  input-ink-color: var(--primary-text-color)
  input-label-ink-color: var(--secondary-text-color)
  input-disabled-ink-color: var(--disabled-text-color)
  input-idle-line-color: var(--divider-color)
  input-hover-line-color: var(--accent-color)
  input-dropdown-icon-color: var(--primary-text-color)

  # Explicit MDC aliases
  mdc-text-field-fill-color: var(--input-fill-color)
  mdc-text-field-disabled-fill-color: var(--input-disabled-fill-color)
  mdc-text-field-ink-color: var(--input-ink-color)
  mdc-text-field-label-ink-color: var(--input-label-ink-color)
  mdc-text-field-disabled-ink-color: var(--input-disabled-ink-color)

  mdc-select-fill-color: var(--input-fill-color)
  mdc-select-disabled-fill-color: var(--input-disabled-fill-color)
  mdc-select-ink-color: var(--input-ink-color)
  mdc-select-label-ink-color: var(--input-label-ink-color)
  mdc-select-disabled-ink-color: var(--input-disabled-ink-color)

  # Web Awesome form aliases
  wa-color-surface-default: var(--card-background-color)
  wa-color-surface-raised: {{ dialog_background_color }}
  wa-form-control-background-color: {{ form_background_color }}
  wa-form-control-value-color: var(--primary-text-color)
  wa-form-control-placeholder-color: var(--secondary-text-color)

  # ---------------------------------------------------------------------------
  # App header, tabs, and newer HA / HACS semantic colors
  # ---------------------------------------------------------------------------
  app-header-background-color: {{ app_header_background_color }}
  app-header-text-color: var(--primary-text-color)
  app-header-selection-bar-color: var(--accent-color)  # Active view tab indicator

  # Shoelace tab colors
  sl-color-primary-600: var(--accent-color)  # Active tab text/icon
  sl-color-neutral-600: var(--app-header-text-color)  # Inactive tab text/icon

  # Neutral fills used by newer HA / HACS / Web Awesome pages
  ha-color-fill-neutral-loud-resting: var(--primary-background-color)
  ha-color-fill-neutral-loud-hover: var(--primary-background-color)
  ha-color-fill-neutral-normal-resting: var(--secondary-background-color)
  ha-color-fill-neutral-normal-hover: var(--secondary-background-color)
  ha-color-fill-neutral-quiet-resting: var(--primary-background-color)
  ha-color-fill-neutral-quiet-hover: var(--primary-background-color)

  # Text shown on neutral surfaces
  ha-color-on-neutral-loud: var(--primary-text-color)
  ha-color-on-neutral-normal: var(--primary-text-color)
  ha-color-on-neutral-quiet: var(--primary-text-color)

  # Explicit Web Awesome aliases for components that read wa-* directly
  wa-color-neutral-fill-loud: var(--ha-color-fill-neutral-loud-resting)
  wa-color-neutral-fill-normal: var(--ha-color-fill-neutral-normal-resting)
  wa-color-neutral-fill-quiet: var(--ha-color-fill-neutral-quiet-hover)
  wa-color-neutral-on-loud: var(--ha-color-on-neutral-loud)
  wa-color-neutral-on-normal: var(--ha-color-on-neutral-normal)
  wa-color-neutral-on-quiet: var(--ha-color-on-neutral-quiet)
  wa-color-neutral-border-loud: var(--ha-color-border-neutral-loud)
  wa-color-neutral-border-normal: var(--ha-color-border-neutral-normal)
  wa-color-neutral-border-quiet: var(--ha-color-border-neutral-quiet)

  # ---------------------------------------------------------------------------
  # Editors and code blocks
  # ---------------------------------------------------------------------------
  markdown-code-background-color: {{ markdown_code_background_color }}
  code-editor-background-color: {{ code_editor_background_color }}
  codemirror-property: var(--accent-color)

  # ---------------------------------------------------------------------------
  # Misc / framework compatibility
  # ---------------------------------------------------------------------------
  lumo-body-text-color: var(--primary-text-color)  # See issue #42

  # ---------------------------------------------------------------------------
  # Custom card tweaks
  # ---------------------------------------------------------------------------
  mcg-title-letter-spacing: .15em
  mini-media-player-base-color: white
  mini-media-player-icon-color: white